[core]
	pager = delta
	editor = vim

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[alias]
	s = status
	a = add
	cm = commit -m
	co = checkout
	br = branch
	lg = log --graph --oneline --decorate --all
	last = log -1 HEAD --stat
	unstage = reset HEAD --
	undo = reset --soft HEAD~1

[pull]
	rebase = false

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[include]
	path = ~/.gitconfig.local
[user]
	name = hscspring
	email = haoshaochun@gmail.com
